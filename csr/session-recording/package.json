{
  "name": "@spotify-confidence/session-recording",
  "license": "Apache-2.0",
  "version": "0.17.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/spotify/confidence-sdk-js.git",
    "directory": "csr/session-recording"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "prebuild": "node sync-version.mjs",
    "build": "yarn run -T tsdown",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "dependencies": {
    "@spotify-confidence/csr-common": "workspace:*",
    "@spotify-confidence/csr-recorder": "workspace:*"
  }
}
